{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "allowJs": true,
    "noEmit": true
  },
  "include": ["tests/**/*.ts", "tests/**/*.tsx", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "cloud-functions/lib"]
} 